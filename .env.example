# =============================================================================
# Alfy2 environment configuration
# Copy to .env and fill in real values. NEVER commit .env. Placeholders only here.
# Every variable below is validated at boot (see docs/CONFIG_SYSTEM.md).
# =============================================================================

# --- Runtime -----------------------------------------------------------------
# Selects default profile. One of: development | staging | production
ALFY_ENV=development
# Log verbosity: debug | info | warn | error
ALFY_LOG_LEVEL=info
# Single-operator mode: the one tenant everything is scoped to.
ALFY_DEFAULT_TENANT_ID=YOUR_DEFAULT_TENANT_UUID
# Ports for the long-running services.
ALFY_API_PORT=8080
ALFY_ORCHESTRATOR_PORT=8090

# --- Supabase (datastore / auth / storage) -----------------------------------
# Project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=YOUR_SUPABASE_URL
# Public anon key (safe for clients).
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Service-role key — SERVER PROCESSES ONLY. Never ship to clients/workers with untrusted input.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Direct Postgres connection string for @alfy2/db (Supabase: Project Settings -> Database ->
# Connection string -> "Transaction"/pooler). Includes the DB password. SERVER-ONLY. Example:
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=YOUR_SUPABASE_POOLER_CONNECTION_STRING

# --- AI controls (off by default — see docs/COST_CONTROL_PLAN.md) -------------
# Global kill switch. false = AI Gateway refuses all model calls.
AI_ENABLED=false
# Cheapest viable default model used when a task does not specify one.
AI_DEFAULT_MODEL=YOUR_CHEAP_DEFAULT_MODEL
# Provider API key (only used when AI_ENABLED=true).
AI_PROVIDER_API_KEY=YOUR_AI_PROVIDER_API_KEY
# Per-feature flags. Default off. Add one per AI-backed capability.
AI_FEATURE_SUMMARIZE=false
AI_FEATURE_DRAFT=false
# Default per-task budget ceilings (override per Task via the Task.budget contract).
AI_MAX_TOKENS_DEFAULT=2000
AI_MAX_COST_USD_DEFAULT=0.05

# --- Agent transport ---------------------------------------------------------
# Base URL the orchestrator uses to reach Python workers (HTTP in Phase 0-2).
WORKERS_BASE_URL=http://localhost:8081

# --- Generic feature flags ---------------------------------------------------
# Pattern: FLAG_<NAME>=true|false. Default risky/expensive features to false.
FLAG_APPROVAL_AUTOEXECUTE_REVERSIBLE=true
